## RPC (専用エンドポイント)
#
# 目的: 共有RPC（例: eth.merkle.io 等）による 429 を避けるため、
# wagmi/viem の通信を専用RPCへ切替します。
#
# 使い方:
# 1) このファイルをコピーして `.env.local` を作成
# 2) どれか1つのURL（Alchemy か Infura）を入れて `NEXT_PUBLIC_RPC_URL` に設定
#
# 例:
# NEXT_PUBLIC_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/<ALCHEMY_API_KEY>"
# NEXT_PUBLIC_RPC_URL="https://mainnet.infura.io/v3/<INFURA_API_KEY>"
#

# 必須（フロントで参照されます）
NEXT_PUBLIC_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/<ALCHEMY_API_KEY>"

# (任意) 参考: Infura を使う場合は上の値を差し替え
# NEXT_PUBLIC_RPC_URL="https://mainnet.infura.io/v3/<INFURA_API_KEY>"

## Python backend (ローカル同居)
# Next.js の /api/bridge/* がここへプロキシします。
CIV_OS_BACKEND_URL="http://127.0.0.1:8000"

# (任意) Next.js が別ポート/別ホストの時に上書き
# CIV_OS_BACKEND_URL="http://localhost:8000"

# (任意) Next -> Bridge のURLを強制する場合（通常は不要）
# CREWAI_BRIDGE_URL="http://127.0.0.1:3000/api/bridge/analyze"

