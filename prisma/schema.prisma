// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  walletAddress   String           @unique
  baseAcesScore   Float            @default(4.0)
  scans           ScanHistory[]
  peakCalib       PeakCalibration?
  careActions     CareAction[]
  claims          Claim[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Claim {
  id            String   @id @default(cuid())
  userId        String?  // ✅ `?` を追加して任意に
  user          User?    @relation(fields: [userId], references: [id]) // ✅ `?` を追加して任意に
  walletAddress String?
  passphrase    String?
  amount        Float?   // ✅ `?` を追加して任意に
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())
}

model ScanHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  omegaScore   Float
  neuralState  String
  logicVersion String   @default("Satsuma-v1.1")
  f0Hz         Float?
  jitterPct    Float?
  shimmerPct   Float?
  hnrDb        Float?
  createdAt    DateTime @default(now())
}

model PeakCalibration {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  peakScore    Float
  lastScore    Float    @default(0)
  isTrapped    Boolean  @default(false)
  proposedSync Boolean  @default(false)
  syncReasonJa String?
  syncedAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CareAction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  actionType  String?
  amount      Float
  impactScore Float    @default(0)
  createdAt   DateTime @default(now())
}